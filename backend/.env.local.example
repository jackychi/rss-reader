# Local development config.
#
# This single file is read by both the Vite frontend and the Go backend.
# VITE_* values are exposed to the browser; keep this setup for local/admin use.

VITE_ASKCAT_BASE_URL=https://api.openai.com/v1
VITE_ASKCAT_API_KEY=
VITE_ASKCAT_MODEL=gpt-4.1-mini
VITE_ASKCAT_CONTEXT_SIZE=30

CATREADER_ADDR=:8080
CATREADER_DB_PATH=data/catreader.db
CATREADER_FEEDS_FILE=../src/data/defaultFeeds.js
CATREADER_REFRESH_INTERVAL=10m
CATREADER_FETCH_TIMEOUT=20s
CATREADER_FETCH_CONCURRENCY=5

CATREADER_USER_DB_DRIVER=mysql
CATREADER_USER_DB_HOST=
CATREADER_USER_DB_PORT=3306
CATREADER_USER_DB_NAME=
CATREADER_USER_DB_USER=
CATREADER_USER_DB_PASSWORD=

CATREADER_FEED_INTRO_REFRESH_INTERVAL=168h
CATREADER_FEED_INTRO_CHECK_INTERVAL=1h
CATREADER_FEED_INTRO_CONCURRENCY=2
