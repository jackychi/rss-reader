# Frontend local development config.
#
# VITE_* values are readable by the browser. Keep AskCat enabled only for the
# local/admin build, not for regular users.

VITE_CATREADER_API_URL=http://localhost:8080

VITE_ASKCAT_BASE_URL=https://api.openai.com/v1
VITE_ASKCAT_API_KEY=
VITE_ASKCAT_MODEL=gpt-4.1-mini
VITE_ASKCAT_CONTEXT_SIZE=30
